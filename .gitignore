venv/
ENV/
env/

# JavaScript dependencies
node_modules/
.npm/

# IDEs and OS metadata
.vscode/
.idea/
.DS_Store
Thumbs.db

# Environment variables / Secrets (Never commit passwords or API keys!)
.env
*.env